const ALL_TOPICS = [...new Set(QUESTIONS.map(q => q.topic))];
let state = {
  selectedTopics: [...ALL_TOPICS],
  mode: 'quiz',
  questionCount: 10,
  queue: [], qIndex: 0,
  score: 0, streak: 0, bestStreak: 0,
  lives: 3, correct: 0, wrong: 0,
  wrongAnswers: [], answered: false,
  timerInterval: null, timerCurrent: 10,
  questionStartTime: 0, totalTime: 0,
  sessionScore: 0,
};

function init() {
  const container = document.getElementById('topic-chips');
  const allChip = document.createElement('div');
  allChip.className = 'chip on';
  allChip.textContent = 'All Topics';
  allChip.onclick = toggleAllTopics;
  container.appendChild(allChip);
  ALL_TOPICS.forEach(t => {
    const c = document.createElement('div');
    c.className = 'chip on';
    c.dataset.topic = t;
    c.textContent = t;
    c.onclick = () => toggleTopic(t, c);
    container.appendChild(c);
  });
  document.querySelectorAll('.mode-card').forEach(c => {
    c.onclick = () => {
      document.querySelectorAll('.mode-card').forEach(x => x.classList.remove('on'));
      c.classList.add('on');
      state.mode = c.dataset.mode;
    };
  });
  document.querySelectorAll('#count-chips .chip').forEach(c => {
    c.onclick = () => {
      document.querySelectorAll('#count-chips .chip').forEach(x => x.classList.remove('on'));
      c.classList.add('on');
      state.questionCount = parseInt(c.dataset.val) || 999;
    };
  });
}

function toggleAllTopics() {
  const chips = document.querySelectorAll('[data-topic]');
  const allOn = state.selectedTopics.length === ALL_TOPICS.length;
  if (allOn) {
    state.selectedTopics = [];
    chips.forEach(c => c.classList.remove('on'));
    document.querySelector('#topic-chips .chip').classList.remove('on');
  } else {
    state.selectedTopics = [...ALL_TOPICS];
    chips.forEach(c => c.classList.add('on'));
    document.querySelector('#topic-chips .chip').classList.add('on');
  }
}

function toggleTopic(topic, chip) {
  if (state.selectedTopics.includes(topic)) {
    if (state.selectedTopics.length === 1) return;
    state.selectedTopics = state.selectedTopics.filter(t => t !== topic);
    chip.classList.remove('on');
    document.querySelector('#topic-chips .chip').classList.remove('on');
  } else {
    state.selectedTopics.push(topic);
    chip.classList.add('on');
    if (state.selectedTopics.length === ALL_TOPICS.length)
      document.querySelector('#topic-chips .chip').classList.add('on');
  }
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('on'));
  document.getElementById('screen-' + id).classList.add('on');
}

function startGame() {
  state.score = 0; state.streak = 0; state.bestStreak = 0;
  state.correct = 0; state.wrong = 0; state.lives = 3;
  state.wrongAnswers = []; state.sessionScore = 0; state.totalTime = 0;
  updateHdrStats();
  let pool = QUESTIONS.filter(q => state.selectedTopics.includes(q.topic));
  if (!pool.length) pool = QUESTIONS;
  pool = shuffle(pool);
  state.queue = pool.slice(0, Math.min(state.questionCount, pool.length));
  state.qIndex = 0;
  showScreen('quiz');
  renderQuestion();
}

function renderQuestion() {
  if (state.qIndex >= state.queue.length) { endGame(); return; }
  const q = state.queue[state.qIndex];
  state.answered = false;
  state.questionStartTime = Date.now();
  document.getElementById('progress-fill').style.width = (state.qIndex / state.queue.length * 100) + '%';
  document.getElementById('q-topic-label').textContent = q.topic;
  document.getElementById('q-count-label').textContent = (state.qIndex + 1) + ' / ' + state.queue.length;
  document.getElementById('q-type-badge').textContent = q.type;
  document.getElementById('q-text').innerHTML = q.q;
  const livesEl = document.getElementById('lives-display');
  livesEl.textContent = state.mode === 'survival' ? '❤️'.repeat(state.lives) + '🖤'.repeat(3 - state.lives) : '';
  const fb = document.getElementById('feedback-box');
  fb.className = 'feedback-box';
  document.getElementById('btn-next').style.display = 'none';
  const opts = shuffle([q.a, ...q.wrong]);
  const grid = document.getElementById('answers-grid');
  grid.innerHTML = '';
  ['A','B','C','D'].forEach((key, i) => {
    if (!opts[i]) return;
    const btn = document.createElement('button');
    btn.className = 'ans-btn';
    btn.innerHTML = '<span class="ans-key">' + key + '</span> ' + opts[i];
    btn.onclick = () => checkAnswer(opts[i], q, btn);
    grid.appendChild(btn);
  });
  clearInterval(state.timerInterval);
  const timerWrap = document.getElementById('timer-wrap');
  const timerFill = document.getElementById('timer-fill');
  if (state.mode === 'timed') {
    timerWrap.style.display = 'block';
    state.timerCurrent = 10;
    timerFill.style.width = '100%';
    timerFill.classList.remove('hurry');
    state.timerInterval = setInterval(() => {
      state.timerCurrent--;
      timerFill.style.width = (state.timerCurrent / 10 * 100) + '%';
      if (state.timerCurrent <= 3) timerFill.classList.add('hurry');
      if (state.timerCurrent <= 0) { clearInterval(state.timerInterval); timeOut(q); }
    }, 1000);
  } else { timerWrap.style.display = 'none'; }
}

function checkAnswer(chosen, q, btn) {
  if (state.answered) return;
  state.answered = true;
  clearInterval(state.timerInterval);
  state.totalTime += (Date.now() - state.questionStartTime) / 1000;
  document.querySelectorAll('.ans-btn').forEach(b => b.disabled = true);
  const isCorrect = chosen === q.a;
  const fb = document.getElementById('feedback-box');
  if (isCorrect) {
    btn.classList.add('correct');
    state.correct++;
    state.streak++;
    if (state.streak > state.bestStreak) state.bestStreak = state.streak;
    const speedBonus = state.mode === 'timed' ? Math.round((state.timerCurrent / 10) * 50) : 0;
    const streakBonus = Math.min(state.streak - 1, 5) * 20;
    state.sessionScore += 100 + streakBonus + speedBonus;
    updateHdrStats();
    fb.className = 'feedback-box ok show';
    let head = '✓ Correct!';
    if (state.streak >= 5) head = '🔥 On fire! ' + state.streak + ' in a row!';
    else if (state.streak >= 3) head = '⚡ ' + state.streak + '-streak! +' + streakBonus + ' bonus';
    document.getElementById('feedback-head').textContent = head;
    document.getElementById('feedback-body').textContent = q.fact;
    if (state.streak === 3 || state.streak === 5 || state.streak === 10) flashStreak(state.streak);
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.ans-btn').forEach(b => {
      if (b.innerHTML.indexOf(q.a) !== -1 && !b.classList.contains('wrong')) b.classList.add('correct');
    });
    state.wrong++;
    state.streak = 0;
    state.wrongAnswers.push({ q: q.q, yours: chosen, correct: q.a });
    updateHdrStats();
    if (state.mode === 'survival') {
      state.lives--;
      document.getElementById('lives-display').textContent = '❤️'.repeat(state.lives) + '🖤'.repeat(3 - state.lives);
      if (state.lives <= 0) {
        fb.className = 'feedback-box bad show';
        document.getElementById('feedback-head').textContent = '💀 Game over! No lives left.';
        document.getElementById('feedback-body').textContent = 'Correct answer: ' + q.a;
        const nb = document.getElementById('btn-next');
        nb.style.display = 'inline-flex';
        nb.textContent = 'See Results';
        nb.onclick = endGame;
        return;
      }
    }
    fb.className = 'feedback-box bad show';
    document.getElementById('feedback-head').textContent = '✗ Not quite';
    document.getElementById('feedback-body').textContent = 'Correct: ' + q.a + '. ' + q.fact;
  }
  const nb = document.getElementById('btn-next');
  nb.style.display = 'inline-flex';
  nb.textContent = state.qIndex + 1 >= state.queue.length ? 'See Results →' : 'Next →';
  nb.onclick = nextQuestion;
}

function timeOut(q) {
  if (state.answered) return;
  state.answered = true;
  document.querySelectorAll('.ans-btn').forEach(b => {
    b.disabled = true;
    if (b.innerHTML.indexOf(q.a) !== -1) b.classList.add('correct');
  });
  state.wrong++; state.streak = 0;
  state.wrongAnswers.push({ q: q.q, yours: '(time up)', correct: q.a });
  const fb = document.getElementById('feedback-box');
  fb.className = 'feedback-box bad show';
  document.getElementById('feedback-head').textContent = '⏱ Time\'s up!';
  document.getElementById('feedback-body').textContent = 'Correct answer: ' + q.a;
  const nb = document.getElementById('btn-next');
  nb.style.display = 'inline-flex';
  nb.onclick = nextQuestion;
  updateHdrStats();
}

function nextQuestion() {
  state.qIndex++;
  document.getElementById('btn-next').onclick = nextQuestion;
  renderQuestion();
}

function quitGame() {
  clearInterval(state.timerInterval);
  showScreen('home');
}

function endGame() {
  clearInterval(state.timerInterval);
  const total = state.correct + state.wrong;
  const pct = total > 0 ? Math.round(state.correct / total * 100) : 0;
  document.getElementById('progress-fill').style.width = '100%';
  let col = 'var(--wrong)';
  if (pct >= 80) col = 'var(--correct)';
  else if (pct >= 60) col = 'var(--gold)';
  document.getElementById('res-score').textContent = pct + '%';
  document.getElementById('res-score').style.color = col;
  const labels = ['Keep at it — revision time! 📚', '', '', '', '', 'Good effort — nearly there!', '','','👍 Solid work!','','🔥 Excellent!','','','','','🌟 Outstanding!','','','','','🏆 Perfect! Anatomy legend.'];
  let lbl = 'Keep practising!';
  if (pct === 100) lbl = '🏆 Perfect score! Anatomy legend.';
  else if (pct >= 90) lbl = '🌟 Outstanding — almost flawless!';
  else if (pct >= 80) lbl = '🔥 Excellent work!';
  else if (pct >= 60) lbl = '👍 Solid — a bit more revision needed.';
  else lbl = '📚 Keep at it — you\'ve got this!';
  document.getElementById('res-label').textContent = lbl;
  document.getElementById('res-correct').textContent = state.correct;
  document.getElementById('res-wrong').textContent = state.wrong;
  document.getElementById('res-streak').textContent = state.bestStreak;
  document.getElementById('res-pts').textContent = state.sessionScore;
  document.getElementById('res-time').textContent = total > 0 ? (state.totalTime / total).toFixed(1) + 's' : '—';
  document.getElementById('res-acc').textContent = pct + '%';
  const rev = document.getElementById('review-section');
  if (state.wrongAnswers.length > 0) {
    rev.style.display = 'block';
    const list = document.getElementById('review-list');
    list.innerHTML = '';
    state.wrongAnswers.forEach(w => {
      const d = document.createElement('div');
      d.className = 'review-item';
      d.innerHTML = '<div class="review-q">' + w.q + '</div><div class="review-yours">Your answer: ' + w.yours + '</div><div class="review-correct">Correct: ' + w.correct + '</div>';
      list.appendChild(d);
    });
  } else { rev.style.display = 'none'; }
  showScreen('results');
}

function flashStreak(n) {
  const el = document.getElementById('streak-flash');
  el.textContent = n + '🔥';
  el.classList.remove('pop');
  void el.offsetWidth;
  el.classList.add('pop');
}

function updateHdrStats() {
  document.getElementById('hdr-streak').textContent = state.streak;
  document.getElementById('hdr-score').textContent = state.sessionScore;
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

init();
</script>
</body>
</html>
